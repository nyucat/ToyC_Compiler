const int base = 2 + 3 * 4;
int global = base;

int add(int a, int b) {
    return a + b;
}

int main() {
    int x = add(global, 1);
    if (x > 10) {
        x = x - 1;
    } else {
        x = x + 1;
    }
    while (x > 0) {
        x = x - 1;
        if (x == 3) {
            continue;
        }
        if (x == 1) {
            break;
        }
    }
    return x;
}
